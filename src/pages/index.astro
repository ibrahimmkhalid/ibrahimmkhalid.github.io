---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.jsx';
import Entry from '../components/sections/entry.astro'
import Projects from '../components/sections/projects.astro'
import { SITE_TITLE, SITE_DESCRIPTION, PROFILE } from '../consts';

export const prerender = true;

const isBuild = false

var firstQuickLink = true;
---


<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header client:load/>
      <div class="flex flex-col" id="top">
        <main class="flex min-w-0 flex-col items-center overflow-x-hidden px-4 sm:px-6">
          {isBuild && (
            <>
              <div class="m-4 rounded-full border-8 border-red-500 p-4">
                (Page experience still being built...)
                <br />
                If you found this page, please explore the buttons just below
              </div>
            </>
          )}
          <div class="min-w-0 w-full max-w-5xl space-y-8 pt-8 pb-8 md:space-y-12 md:pt-12 md:pb-12">
            <section>
              <div class="mb-5">
                <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">{PROFILE.name}</h1>
                <h2 class="pt-1 text-lg text-gray-600 sm:text-xl">{PROFILE.role} · {PROFILE.location}</h2>
              </div>
              <p class="text-base leading-7 sm:text-lg">{PROFILE.blurb}</p>
              <div class="grid grid-cols-2 gap-2 pt-4 sm:grid-cols-4">
                {PROFILE.quickLinks.map((l) => {
                  var btnClass = "flex min-h-10 w-full items-center justify-center rounded-md border border-gray-200 px-4 py-2 text-center text-sm font-medium transition hover:border-gray-400 sm:text-base";
                  if (firstQuickLink) {
                    btnClass = btnClass + " bg-black text-white";
                    firstQuickLink = false;
                  }
                  return (
                    <div>
                      <a class="block" href={l.href} target="_blank">
                        <span class={btnClass}>{l.name}</span>
                      </a>
                    </div>
                  );
                })}
              </div>
            </section>
            <section id="experience">
              <Entry section="experience" />
            </section>
            <section id="education">
              <Entry section="education" />
            </section>
            <section id="projects">
              <Projects />
            </section>
          </div>
        </main>
      </div>
	</body>
</html>
